# ── Feature Flags ─────────────────────────────────────────────
USE_S3=true
USE_POSTGRES=true
USE_REDIS=true        # set false to use in-process cache (no Redis needed)
DEBUG=false

# ── Supabase ──────────────────────────────────────────────────
DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=${DB_URL}

S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_ACCESS_KEY=<supabase-s3-access-key>
S3_SECRET_KEY=<supabase-s3-secret-key>
S3_BUCKET_NAME=models

# ── Redis (Upstash free tier recommended) ─────────────────────
# Sign up free at https://upstash.com → create Redis DB → copy URL
REDIS_URL=redis://default:<password>@<host>.upstash.io:6379
REDIS_PREDICTION_TTL=3600   # 1 hour
REDIS_OHLCV_TTL=300         # 5 minutes
REDIS_VALIDATION_TTL=86400  # 24 hours

# ── Prediction staleness ──────────────────────────────────────
# How many hours before a stored prediction is considered stale
PREDICTION_STALE_HOURS=24

# ── Admin ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=<your-secret-key>
