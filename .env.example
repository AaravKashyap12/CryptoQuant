# Feature flags
USE_S3=true
USE_POSTGRES=true
USE_REDIS=false
DEBUG=false
ALLOW_MOCK_DATA=false

# Supabase Postgres
DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=${DB_URL}

# Supabase S3-compatible storage
S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_ACCESS_KEY=<supabase-s3-access-key>
S3_SECRET_KEY=<supabase-s3-secret-key>
S3_BUCKET_NAME=models

# Redis (Upstash free tier recommended)
REDIS_URL=redis://default:<password>@<host>.upstash.io:6379
REDIS_PREDICTION_TTL=3600
REDIS_OHLCV_TTL=300
REDIS_VALIDATION_TTL=86400

# Prediction staleness
PREDICTION_STALE_HOURS=24

# Free signal provider. No key required.
# Optional premium path: ONCHAIN_PROVIDER=glassnode with GLASSNODE_API_KEY.
ONCHAIN_PROVIDER=free
ONCHAIN_CACHE_TTL=3600
GLASSNODE_API_KEY=

# Admin
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=<your-secret-key>
