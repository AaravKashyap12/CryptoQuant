# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored so secrets stay local.

# Your FastAPI backend URL.
# In development: leave empty — the Vite proxy in vite.config.js forwards /api → localhost:8001
# In production:  set to your Railway/Render URL, e.g. https://cryptoquant-api.up.railway.app
VITE_API_URL=
