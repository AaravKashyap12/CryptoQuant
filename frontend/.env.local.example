# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored so secrets stay local.

# Your FastAPI backend URL.
# In development: leave empty if using the Vite proxy in vite.config.js.
# In production previews: set to your Render URL.
VITE_API_URL=

# Creator links shown in the top header rail
VITE_GITHUB_URL=https://github.com/AaravKashyap12
VITE_LINKEDIN_URL=
VITE_X_URL=
