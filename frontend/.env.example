# ── CryptoQuant Frontend Environment ──────────────────────────────────────────
#
# Copy this file to .env.local for local development.
# In production (Vercel), set these in the Vercel dashboard → Settings → Environment Variables.
#
# NOTE: In development, the Vite proxy (vite.config.js) automatically forwards
# /api/* to localhost:8001 — so you only need VITE_API_URL if your backend
# is running on a different host/port.

# Backend API base URL (without /api/v1 suffix — the client adds it automatically)
# Production example:
VITE_API_URL=https://cryptoquant-api.onrender.com

# Local dev override (only needed if NOT using the Vite proxy, e.g. backend on different port)
# VITE_API_URL=http://localhost:8001
