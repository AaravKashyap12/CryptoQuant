# CryptoQuant frontend environment
#
# Copy this file to .env.local for local development.
# In production, set these in Vercel > Project > Settings > Environment Variables.
#
# NOTE: In development, the Vite proxy (vite.config.js) automatically forwards
# /api/* to localhost:8002, so you only need VITE_API_URL if your backend
# is running on a different host/port.

# Backend API base URL. Do not include /api/v1; the client adds it.
VITE_API_URL=https://cryptoquant-api.onrender.com

# Local dev override (only needed if NOT using the Vite proxy)
# VITE_API_URL=http://localhost:8002

# Creator links shown in the top header rail
VITE_GITHUB_URL=https://github.com/AaravKashyap12
VITE_LINKEDIN_URL=
VITE_X_URL=
